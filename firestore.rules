rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    
    // Función para verificar propiedad del documento
    function isOwner(userId) {
      return request.auth != null && request.auth.uid == userId;
    }

    // PRODUCTOS: Lectura pública para atraer tráfico (SEO)
    // Escritura restringida a Admin o servicios autorizados
    match /productos/{productId} {
      allow read: if true;
      allow write: if request.auth != null;
      
      match /historial_precios/{historyId} {
        allow read: if true;
        allow write: if request.auth != null;
      }
    }

    // RASTREOS: Privacidad total del usuario. 
    // Solo el dueño puede ver y gestionar sus alertas.
    match /trackings/{trackingId} {
      allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
      allow read, update, delete: if isOwner(resource.data.userId);
    }

    // PERFILES DE USUARIO: Soporte para Monetización (SaaS/Suscripciones)
    // Almacena si el usuario es 'free' o 'premium'
    match /perfiles_usuario/{userId} {
      allow read: if isOwner(userId);
      allow write: if isOwner(userId); // El usuario puede actualizar preferencias básicas
    }

    // ANALÍTICA Y CONSULTAS: Solo escritura para métricas de negocio
    // Esto alimenta tu activo de "Venta de Insights" a largo plazo
    match /consultas_busqueda/{docId} {
      allow create: if true; // Cualquier búsqueda genera un registro de analítica
      allow read: if request.auth != null; // Solo administradores/empleados para análisis
    }

    // REGLA POR DEFECTO: Denegar todo lo demás para máxima seguridad
    match /{document=**} {
      allow read, write: if false;
    }
  }
}
